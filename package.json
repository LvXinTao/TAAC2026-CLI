{
  "name": "taiji-metrics-scraper-skill",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "scrape": "node scripts/scrape-taiji.mjs",
    "scrape:all": "node scripts/scrape-taiji.mjs --all",
    "diff:config": "node scripts/compare-config-yaml.mjs",
    "prepare:submit": "node scripts/prepare-taiji-submit.mjs",
    "submit": "node scripts/submit-taiji.mjs",
    "test": "node --test scripts/tests/*.test.mjs",
    "check": "node --check scripts/scrape-taiji.mjs && node --check scripts/compare-config-yaml.mjs && node --check scripts/prepare-taiji-submit.mjs && node --check scripts/submit-taiji.mjs"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "playwright": "^1.52.0",
    "cos-nodejs-sdk-v5": "^2.15.4"
  }
}
